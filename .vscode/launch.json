{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run Spring Boot (local DB)",
      "request": "launch",
      "mainClass": "com.first.pfm.main.StartApplication",
      "projectName": "first.pfm",
      "vmArgs": "-Dspring.profiles.active=local"
    },
    {
      "type": "java",
      "name": "Debug Current Java File",
      "request": "launch",
      "mainClass": "${file}"
    },
    {
      "type": "chrome",
      "name": "Debug Frontend (Chrome)",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/src"
    }
  ],
  "compounds": []
}
